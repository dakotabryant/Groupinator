<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

    <Frame name="GroupinatorPopupMenuFrameTemplate" enableMouse="true" clampedToScreen="true" virtual="true" inherits="BackdropTemplate">
        <KeyValues>
            <KeyValue key="backdropInfo" type="global" value="BACKDROP_TOOLTIP_0_16_128"/>
        </KeyValues>
    </Frame>

    <Button name="GroupinatorPopupMenuButtonTemplate" motionScriptsWhileDisabled="true" virtual="true">
        <Size x="205" y="20"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString parentKey="Text" inherits="GameFontHighlight" justifyH="LEFT">
                    <Size x="0" y="18"/>
                    <Anchors>
                        <Anchor point="LEFT" x="2"/>
                        <Anchor point="RIGHT" x="-2"/>
                    </Anchors>
                    <Color r="0.90" g="0.90" b="0.90"/>
                </FontString>
            </Layer>
        </Layers>
        <NormalTexture parentKey="NormalTexture">
            <Anchors>
                <Anchor point="TOPLEFT" x="0" y="-1"/>
                <Anchor point="BOTTOMRIGHT" x="0" y="1"/>
            </Anchors>
        </NormalTexture>
        <HighlightTexture parentKey="HighlightTexture">
            <Anchors>
                <Anchor point="TOPLEFT" x="-2" y="0"/>
                <Anchor point="BOTTOMRIGHT" x="2" y="0"/>
            </Anchors>
            <Color r="1" g=".82" b="0" a=".20"/>
        </HighlightTexture>
    </Button>

    <Frame name="GroupinatorDropDownPopupMenuTemplate" virtual="true" inherits="BackdropTemplate">
        <Size x="145" y="24"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString parentKey="Text" inherits="GameFontHighlight" wordwrap="false" justifyH="LEFT">
                    <Size x="100" y="18"/>
                    <Anchors>
                        <Anchor point="LEFT" x="8" y="0"/>
                    </Anchors>
                    <Color r="0.90" g="0.90" b="0.90"/>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Button parentKey="Button" motionScriptsWhileDisabled="true">
                <Size x="18" y="18"/>
                <Anchors>
                    <Anchor point="RIGHT" x="-4" y="0"/>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString parentKey="Arrow" inherits="GameFontNormal" text="v">
                            <Anchors>
                                <Anchor point="CENTER"/>
                            </Anchors>
                            <Color r="0.60" g="0.60" b="0.65"/>
                        </FontString>
                    </Layer>
                </Layers>
                <HighlightTexture setAllPoints="true" alphaMode="ADD">
                    <Color r="1" g="0.82" b="0" a="0.20"/>
                </HighlightTexture>
                <Scripts>
                    <OnEnter>self.Arrow:SetTextColor(0.95, 0.80, 0.30)</OnEnter>
                    <OnLeave>self.Arrow:SetTextColor(0.60, 0.60, 0.65)</OnLeave>
                </Scripts>
            </Button>
        </Frames>
    </Frame>
</Ui>

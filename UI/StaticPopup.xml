<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
    <Button name="GroupinatorStaticPopupButtonTemplate" virtual="true" inherits="BackdropTemplate">
        <Size x="128" y="24"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture setAllPoints="true">
                    <Color r="0.12" g="0.12" b="0.15" a="0.90"/>
                </Texture>
            </Layer>
        </Layers>
        <ButtonText name="$parentText" parentKey="Text">
            <Anchors>
                <Anchor point="CENTER" y="1"/>
            </Anchors>
        </ButtonText>
        <HighlightTexture setAllPoints="true" alphaMode="ADD">
            <Color r="1" g="0.82" b="0" a="0.15"/>
        </HighlightTexture>
        <NormalFont style="GameFontNormal"/>
        <DisabledFont style="GameFontDisable"/>
        <HighlightFont style="GameFontHighlight"/>
    </Button>
    <Frame name="GroupinatorStaticPopupTemplate" toplevel="true" enableKeyboard="true" enableMouse="true"
           frameStrata="DIALOG" hidden="true" virtual="true" inherits="BackdropTemplate">
        <Size x="320" y="72"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parentText" parentKey="Text" inherits="GameFontHighlight">
                    <Size x="1" y="0"/>
                    <Anchors>
                        <Anchor point="TOP" x="0" y="-16"/>
                    </Anchors>
                    <Color r="0.90" g="0.90" b="0.90"/>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Button name="$parentButton1" inherits="GroupinatorStaticPopupButtonTemplate" parentKey="Button1" id="1"/>
            <Button name="$parentButton2" inherits="GroupinatorStaticPopupButtonTemplate" parentKey="Button2" id="2"/>
            <Button name="$parentButton3" inherits="GroupinatorStaticPopupButtonTemplate" parentKey="Button3" id="3"/>
            <Button name="$parentButton4" inherits="GroupinatorStaticPopupButtonTemplate" parentKey="Button4" id="4"/>
            <EditBox name="$parentEditBox" historyLines="1" hidden="true" parentKey="EditBox">
                <Size x="130" y="32"/>
                <Anchors>
                    <Anchor point="BOTTOM" x="0" y="45"/>
                </Anchors>
                <FontString inherits="ChatFontNormal"/>
            </EditBox>
        </Frames>
    </Frame>
</Ui>
